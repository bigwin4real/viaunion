{
  "name": "viarail-local-4005",
  "version": "1.0.0",
  "description": "VIA Rail Local 4005 Steward Portal with PDF form filling",
  "type": "module",
  "scripts": {
    "dev": "python3 -m http.server 4005",
    "build": "npm run build:workers",
    "build:workers": "esbuild functions/*.js --bundle --format=esm --outdir=functions/dist",
    "deploy": "wrangler pages deploy . --project-name viarail4005moncton"
  },
  "dependencies": {
    "pdf-lib": "^1.17.1",
    "form-data": "^4.0.0",
    "node-fetch": "^3.3.0"
  },
  "devDependencies": {
    "esbuild": "^0.20.0"
  }
}
